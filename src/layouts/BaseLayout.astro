---
import SiteContainer from '../components/SiteContainer.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

export interface Props {
  title?: string;
}

const { title = 'Full-Stack Developer' } = Astro.props;
---

<style global lang="scss">
  @use '../scss/type';
  @use '../scss/spacing';
  @use '../scss/colors';

  * {
    box-sizing: border-box;
  }

  html {
    --text-color: #{colors.$text-dark};
    --bg-color: #{colors.$bg-light};
  }

  @media (prefers-color-scheme: dark) {
    html {
      --text-color: #{colors.$text-light};
      --bg-color: #{colors.$bg-dark};
    }
  }
  
  body {
    font-family: type.$font-family-base;
    font-size: type.$font-size-base;
    line-height: type.$line-height;
    background-color: var(--bg-color);
    color: var(--text-color);

    @include spacing.m(0);
  }
</style>

<style>
  main {
    flex: 1;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🦑</text></svg>" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} - Joseph Race</title>
  </head>
  <body>
    <SiteContainer>
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </SiteContainer>
  </body>
</html>
